PORT=5000

# Local DB (ignored when DATABASE_URL is set by Railway)
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_HOST=localhost
DB_PORT=5432
DB_NAME=synthcs_db

# Railway provides this automatically — leave blank locally
DATABASE_URL=

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Your deployed frontend URL (set this in Railway dashboard)
FRONTEND_URL=https://your-app.vercel.app

# Your deployed Node backend URL (for email verification links)
BACKEND_URL=https://your-node-service.railway.app

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=SynthCS <no-reply@synthcs.app>
